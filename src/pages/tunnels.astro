---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import Tooltip from '../components/Tooltip.astro';
---

<Base
  title="SSH Tunnel Builder — SSH Toolkit"
  description="Monte comandos de SSH Tunnel visualmente. Local (-L), Remote (-R) e Dynamic (-D) com diagramas e saída de configuração."
>
  <header class="page-header">
    <h1 class="page-header__title">
      <span class="text-accent">$</span> Tunnel Builder
    </h1>
    <p class="page-header__tagline">
      Monte comandos de SSH Tunnel com diagramas visuais.
    </p>
  </header>

  <!-- Use-case cards -->
  <section class="section">
    <div class="usecase-cards">
      <button class="usecase-card" data-usecase="remote-db">
        <span class="usecase-card__icon">🗄</span>
        <span class="usecase-card__title">Acessar banco remoto</span>
        <span class="usecase-card__desc">PostgreSQL, MySQL via túnel local</span>
      </button>
      <button class="usecase-card" data-usecase="expose-local">
        <span class="usecase-card__icon">🌐</span>
        <span class="usecase-card__title">Expor servidor local</span>
        <span class="usecase-card__desc">Compartilhe seu dev server</span>
      </button>
      <button class="usecase-card" data-usecase="socks-proxy">
        <span class="usecase-card__icon">🔒</span>
        <span class="usecase-card__title">Navegar via proxy</span>
        <span class="usecase-card__desc">SOCKS proxy pela rede remota</span>
      </button>
    </div>
    <div class="usecase-banner" id="usecase-banner" hidden>
      <span id="usecase-banner-text"></span>
      <button class="usecase-banner__close" id="usecase-banner-close" aria-label="Fechar">&times;</button>
    </div>
  </section>

  <!-- Tunnel Type Selector -->
  <section class="section">
    <div class="type-selector" id="type-selector">
      <button class="type-btn type-btn--active" data-type="local">
        <span class="type-btn__flag">-L</span>
        <span class="type-btn__label">Local Forward <Tooltip text="Encaminha uma porta da sua máquina para um destino remoto através do servidor SSH. Ex: acessar um banco de dados remoto como se fosse local." /></span>
      </button>
      <button class="type-btn" data-type="remote">
        <span class="type-btn__flag">-R</span>
        <span class="type-btn__label">Remote Forward <Tooltip text="Expõe uma porta no servidor SSH que redireciona de volta para a sua máquina. Ex: permitir que colegas acessem seu servidor de desenvolvimento." /></span>
      </button>
      <button class="type-btn" data-type="dynamic">
        <span class="type-btn__flag">-D</span>
        <span class="type-btn__label">Dynamic (SOCKS) <Tooltip text="Cria um proxy SOCKS na sua máquina. Todo tráfego configurado para usar o proxy passa pelo servidor SSH. Útil para navegar como se estivesse na rede remota." /></span>
      </button>
    </div>
  </section>

  <!-- Tunnel Parameters -->
  <section class="section card" id="tunnel-form">
    <h2 class="section__title">Tunnel</h2>
    <div class="form-grid">
      <div class="form-group">
        <label for="listen-port" id="label-listen-port">Porta de escuta (sua máquina)</label>
        <input type="number" id="listen-port" value="8080" min="1" max="65535" />
      </div>
      <div class="form-group">
        <label for="bind-addr">Bind Address <span class="text-muted">(opcional)</span> <Tooltip text="Em qual interface escutar. 'localhost' (padrão) = só local. '0.0.0.0' = todas as interfaces (use com cautela — expõe a porta na rede)." /></label>
        <input type="text" id="bind-addr" placeholder="localhost" />
      </div>
      <div class="form-group" id="group-dest-host">
        <label for="dest-host" id="label-dest-host">Host de destino (visto do servidor)</label>
        <input type="text" id="dest-host" value="localhost" />
      </div>
      <div class="form-group" id="group-dest-port">
        <label for="dest-port" id="label-dest-port">Porta de destino</label>
        <input type="number" id="dest-port" value="8080" min="1" max="65535" />
      </div>
    </div>
  </section>

  <!-- SSH Connection -->
  <section class="section card">
    <h2 class="section__title">Conexão SSH</h2>
    <div class="form-grid">
      <div class="form-group">
        <label for="ssh-server">Servidor SSH</label>
        <input type="text" id="ssh-server" placeholder="seu-servidor.com" />
      </div>
      <div class="form-group">
        <label for="ssh-user">Usuário <span class="text-muted">(opcional)</span></label>
        <input type="text" id="ssh-user" placeholder="deploy" />
      </div>
      <div class="form-group">
        <label for="ssh-port">Porta <span class="text-muted">(padrão: 22)</span></label>
        <input type="number" id="ssh-port" value="22" min="1" max="65535" />
      </div>
      <div class="form-group">
        <label for="jump-host">Jump Host <span class="text-muted">(opcional)</span> <Tooltip text="Servidor intermediário para chegar ao destino (ProxyJump). Útil quando o servidor SSH não é acessível diretamente pela internet." /></label>
        <input type="text" id="jump-host" placeholder="bastion" />
      </div>
      <div class="form-group">
        <label for="identity-file">Chave Privada <span class="text-muted">(opcional)</span></label>
        <input type="text" id="identity-file" placeholder="~/.ssh/id_ed25519" />
      </div>
    </div>
  </section>

  <!-- Options -->
  <section class="section card">
    <h2 class="section__title">Opções</h2>
    <div class="options-grid">
      <label class="toggle">
        <input type="checkbox" id="opt-no-shell" checked />
        <span class="toggle__track"></span>
        <span>Sem shell (-N) <Tooltip text="Não abre um shell remoto. Use quando só precisa do túnel, sem executar comandos no servidor." /></span>
      </label>
      <label class="toggle">
        <input type="checkbox" id="opt-background" />
        <span class="toggle__track"></span>
        <span>Background (-f) <Tooltip text="Envia o SSH para segundo plano após autenticação. Combine com -N para túneis que rodam como daemon." /></span>
      </label>
      <label class="toggle">
        <input type="checkbox" id="opt-compression" />
        <span class="toggle__track"></span>
        <span>Compressão (-C)</span>
      </label>
      <label class="toggle">
        <input type="checkbox" id="opt-exit-failure" checked />
        <span class="toggle__track"></span>
        <span>ExitOnForwardFailure <Tooltip text="Aborta se a porta do túnel não puder ser reservada. Previne falhas silenciosas onde o SSH conecta mas o túnel não funciona." /></span>
      </label>
    </div>

    <div class="form-grid" style="margin-top: 1rem;">
      <div class="form-group">
        <label for="alive-interval">ServerAliveInterval <span class="text-muted">(s)</span> <Tooltip text="Segundos entre pings de keepalive. Evita que firewalls e NATs derrubem conexões ociosas." /></label>
        <input type="number" id="alive-interval" value="60" min="0" />
      </div>
      <div class="form-group">
        <label for="alive-count">ServerAliveCountMax</label>
        <input type="number" id="alive-count" value="3" min="0" />
      </div>
    </div>
  </section>

  <!-- Diagram -->
  <section class="section" id="diagram-section">
    <h2 class="section__title">Como funciona</h2>
    <div class="diagram card" id="tunnel-diagram">
      <div class="diagram__flow">
        <span class="diagram__node diagram__node--left" id="diag-left">localhost:8080</span>
        <span class="diagram__arrow">&mdash;&mdash; SSH &mdash;&mdash;&gt;</span>
        <span class="diagram__node diagram__node--middle" id="diag-middle">server</span>
        <span class="diagram__arrow">&mdash;&mdash;&gt;</span>
        <span class="diagram__node diagram__node--right" id="diag-right">localhost:8080</span>
      </div>
      <p class="diagram__desc" id="diag-desc"></p>
    </div>
  </section>

  <!-- Output: SSH Command -->
  <section class="section">
    <h2 class="section__title">Comando SSH</h2>
    <div class="code-preview-wrapper">
      <button class="btn btn--sm copy-btn" data-copy="output-command">Copiar</button>
      <div class="code-preview">
        <code id="output-command">ssh -N -L 8080:localhost:8080 server</code>
      </div>
    </div>
  </section>

  <!-- Output: Autossh -->
  <section class="section">
    <h2 class="section__title">Persistente (autossh)</h2>
    <div class="code-preview-wrapper">
      <button class="btn btn--sm copy-btn" data-copy="output-autossh">Copiar</button>
      <div class="code-preview">
        <code id="output-autossh">autossh -M 0 -N -L 8080:localhost:8080 server</code>
      </div>
    </div>
  </section>

  <!-- Output: SSH Config -->
  <section class="section">
    <div class="config-header">
      <h2 class="section__title">Equivalente ~/.ssh/config</h2>
      <div class="form-group form-group--inline">
        <label for="host-alias">Host alias:</label>
        <input type="text" id="host-alias" value="my-tunnel" class="input--sm" />
      </div>
    </div>
    <div class="code-preview-wrapper">
      <button class="btn btn--sm copy-btn" data-copy="output-config">Copiar</button>
      <div class="code-preview">
        <code id="output-config"></code>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  .page-header {
    text-align: center;
    padding: 2rem 0 1.5rem;
  }

  .page-header__title {
    font-size: 1.75rem;
    letter-spacing: -0.02em;
  }

  .page-header__tagline {
    margin-top: 0.5rem;
    color: var(--text-secondary);
    font-style: italic;
  }

  .section__title {
    font-size: 1rem;
    color: var(--accent);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Type Selector */
  .type-selector {
    display: flex;
    gap: 0.5rem;
  }

  .type-btn {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: all var(--transition);
    font-family: var(--font-mono);
  }

  .type-btn:hover {
    border-color: var(--accent);
    box-shadow: var(--glow-sm);
  }

  .type-btn--active {
    border-color: var(--accent);
    background: var(--accent-glow);
  }

  .type-btn__flag {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
  }

  .type-btn__label {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  /* Options Grid */
  .options-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  /* Diagram */
  .diagram__flow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0.5rem 0;
  }

  .diagram__node {
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.875rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .diagram__node--left {
    background: var(--accent-glow);
    border: 1px solid var(--accent-dim);
    color: var(--accent);
  }

  .diagram__node--middle {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-primary);
  }

  .diagram__node--right {
    background: var(--success-glow);
    border: 1px solid var(--success);
    color: var(--success);
  }

  .diagram__arrow {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .diagram__desc {
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 0.75rem;
    line-height: 1.5;
  }

  /* Config header */
  .config-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .config-header .section__title {
    margin-bottom: 0;
  }

  .form-group--inline {
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
  }

  .input--sm {
    width: 140px;
    font-size: 0.875rem;
    padding: 0.25rem 0.5rem;
  }

  @media (max-width: 640px) {
    .type-selector {
      flex-direction: column;
    }

    .options-grid {
      grid-template-columns: 1fr;
    }

    .diagram__flow {
      flex-direction: column;
    }

    .config-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  import {
    generateSshCommand,
    generateAutosshCommand,
    generateSshConfig,
    generateDiagram,
  } from '../lib/tunnel-generator';
  import type {
    TunnelConfig,
    TunnelSpec,
    TunnelOptions,
    TunnelType,
  } from '../lib/types';
  import { copyToClipboard } from '../lib/clipboard';

  let currentType: TunnelType = 'local';

  // --- DOM refs ---
  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;

  const typeBtns = document.querySelectorAll<HTMLButtonElement>('.type-btn');

  // Unified fields
  const listenPort = $<HTMLInputElement>('listen-port');
  const bindAddr = $<HTMLInputElement>('bind-addr');
  const destHost = $<HTMLInputElement>('dest-host');
  const destPort = $<HTMLInputElement>('dest-port');
  const groupDestHost = $<HTMLElement>('group-dest-host');
  const groupDestPort = $<HTMLElement>('group-dest-port');
  const labelListenPort = $<HTMLElement>('label-listen-port');
  const labelDestHost = $<HTMLElement>('label-dest-host');
  const labelDestPort = $<HTMLElement>('label-dest-port');

  // Outputs
  const outputCommand = $<HTMLElement>('output-command');
  const outputAutossh = $<HTMLElement>('output-autossh');
  const outputConfig = $<HTMLElement>('output-config');

  // Diagram
  const diagLeft = $<HTMLElement>('diag-left');
  const diagMiddle = $<HTMLElement>('diag-middle');
  const diagRight = $<HTMLElement>('diag-right');
  const diagDesc = $<HTMLElement>('diag-desc');

  // --- Label configs per type ---
  const labelConfig = {
    local: {
      listenPort: 'Porta de escuta (sua máquina)',
      destHost: 'Host de destino (visto do servidor)',
      destPort: 'Porta de destino',
      showDest: true,
      defaults: { listenPort: 8080, destHost: 'localhost', destPort: 8080 },
    },
    remote: {
      listenPort: 'Porta de escuta (no servidor)',
      destHost: 'Host de destino (sua máquina)',
      destPort: 'Porta de destino',
      showDest: true,
      defaults: { listenPort: 8080, destHost: 'localhost', destPort: 3000 },
    },
    dynamic: {
      listenPort: 'Porta SOCKS (sua máquina)',
      destHost: '',
      destPort: '',
      showDest: false,
      defaults: { listenPort: 1080, destHost: 'localhost', destPort: 0 },
    },
  };

  // --- Type switching ---
  function switchType(type: TunnelType) {
    currentType = type;
    const cfg = labelConfig[type];

    labelListenPort.textContent = cfg.listenPort;
    labelDestHost.textContent = cfg.destHost;
    labelDestPort.textContent = cfg.destPort;
    groupDestHost.hidden = !cfg.showDest;
    groupDestPort.hidden = !cfg.showDest;

    listenPort.value = String(cfg.defaults.listenPort);
    destHost.value = cfg.defaults.destHost;
    destPort.value = String(cfg.defaults.destPort);
    bindAddr.value = '';

    typeBtns.forEach((b) => b.classList.remove('type-btn--active'));

    update();
  }

  typeBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.type as TunnelType;
      switchType(type);
      btn.classList.add('type-btn--active');
    });
  });

  // --- Build config from form ---
  function getTunnelSpec(): TunnelSpec {
    const bind = bindAddr.value || undefined;
    switch (currentType) {
      case 'local':
        return {
          type: 'local',
          localPort: Number(listenPort.value) || 8080,
          remoteHost: destHost.value || 'localhost',
          remotePort: Number(destPort.value) || 8080,
          bindAddress: bind,
        };
      case 'remote':
        return {
          type: 'remote',
          remotePort: Number(listenPort.value) || 8080,
          localHost: destHost.value || 'localhost',
          localPort: Number(destPort.value) || 3000,
          bindAddress: bind,
        };
      case 'dynamic':
        return {
          type: 'dynamic',
          localPort: Number(listenPort.value) || 1080,
          bindAddress: bind,
        };
    }
  }

  function getOptions(): TunnelOptions {
    return {
      sshServer: ($<HTMLInputElement>('ssh-server')).value || 'server',
      sshUser: ($<HTMLInputElement>('ssh-user')).value || undefined,
      sshPort: Number(($<HTMLInputElement>('ssh-port')).value) || 22,
      jumpHost: ($<HTMLInputElement>('jump-host')).value || undefined,
      identityFile: ($<HTMLInputElement>('identity-file')).value || undefined,
      noShell: ($<HTMLInputElement>('opt-no-shell')).checked,
      background: ($<HTMLInputElement>('opt-background')).checked,
      compression: ($<HTMLInputElement>('opt-compression')).checked,
      exitOnForwardFailure: ($<HTMLInputElement>('opt-exit-failure')).checked,
      serverAliveInterval: Number(($<HTMLInputElement>('alive-interval')).value) || undefined,
      serverAliveCountMax: Number(($<HTMLInputElement>('alive-count')).value) || undefined,
    };
  }

  function getConfig(): TunnelConfig {
    return {
      tunnels: [getTunnelSpec()],
      options: getOptions(),
    };
  }

  // --- Update outputs ---
  function update() {
    const config = getConfig();
    const alias = ($<HTMLInputElement>('host-alias')).value || 'my-tunnel';

    outputCommand.textContent = generateSshCommand(config);
    outputAutossh.textContent = generateAutosshCommand(config);
    outputConfig.textContent = generateSshConfig(config, alias);

    // Diagram
    const tunnel = config.tunnels[0];
    const diagram = generateDiagram(tunnel, config.options);
    diagLeft.textContent = diagram.left;
    diagMiddle.textContent = diagram.middle;
    diagRight.textContent = diagram.right;
    diagDesc.textContent = diagram.description;
  }

  // --- Listen to all inputs ---
  document.querySelectorAll('input').forEach((input) => {
    input.addEventListener('input', update);
    input.addEventListener('change', update);
  });

  // --- Copy buttons ---
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.dataset.copy;
      if (!targetId) return;
      const target = $(targetId);
      if (!target) return;
      const success = await copyToClipboard(target.textContent || '');
      const original = btn.textContent;
      btn.textContent = success ? 'Copiado!' : 'Erro';
      setTimeout(() => (btn.textContent = original), 1500);
    });
  });

  // --- Use-case cards ---
  const usecaseBanner = $<HTMLElement>('usecase-banner');
  const usecaseBannerText = $<HTMLElement>('usecase-banner-text');

  const usecases: Record<string, { type: TunnelType; listenPort: number; destHost: string; destPort: number; server: string; user: string; alias: string; banner: string }> = {
    'remote-db': {
      type: 'local', listenPort: 5432, destHost: 'db.internal', destPort: 5432,
      server: 'bastion.exemplo.com', user: 'deploy', alias: 'db-tunnel',
      banner: 'Exemplo carregado — após conectar, use "psql -h localhost -p 5432" para acessar o banco remoto como se fosse local.',
    },
    'expose-local': {
      type: 'remote', listenPort: 8080, destHost: 'localhost', destPort: 3000,
      server: 'servidor.exemplo.com', user: 'deploy', alias: 'expose-dev',
      banner: 'Exemplo carregado — seu colega poderá acessar seu app local em servidor.exemplo.com:8080.',
    },
    'socks-proxy': {
      type: 'dynamic', listenPort: 1080, destHost: '', destPort: 0,
      server: 'proxy.exemplo.com', user: 'usuario', alias: 'socks-proxy',
      banner: 'Exemplo carregado — configure seu navegador para usar proxy SOCKS5 em localhost:1080.',
    },
  };

  document.querySelectorAll<HTMLButtonElement>('.usecase-card').forEach((card) => {
    card.addEventListener('click', () => {
      const uc = usecases[card.dataset.usecase!];
      if (!uc) return;

      // Switch type (this resets fields and updates labels)
      switchType(uc.type);
      typeBtns.forEach((b) => {
        b.classList.toggle('type-btn--active', b.dataset.type === uc.type);
      });

      // Fill fields
      listenPort.value = String(uc.listenPort);
      destHost.value = uc.destHost;
      destPort.value = String(uc.destPort);
      ($<HTMLInputElement>('ssh-server')).value = uc.server;
      ($<HTMLInputElement>('ssh-user')).value = uc.user;
      ($<HTMLInputElement>('host-alias')).value = uc.alias;

      // Show banner
      usecaseBannerText.textContent = uc.banner;
      usecaseBanner.hidden = false;

      update();

      // Scroll to form
      $<HTMLElement>('tunnel-form').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  $<HTMLElement>('usecase-banner-close').addEventListener('click', () => {
    usecaseBanner.hidden = true;
  });

  // Initial render
  update();
</script>
