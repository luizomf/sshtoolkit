---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import Tooltip from '../components/Tooltip.astro';
---

<Base
  title="SSH Tunnel Builder — SSH Toolkit"
  description="Monte comandos de SSH Tunnel visualmente. Local (-L), Remote (-R) e Dynamic (-D) com diagramas e saída de configuração."
>
  <header class="page-header">
    <h1 class="page-header__title">
      <span class="text-accent">$</span> Tunnel Builder
    </h1>
    <p class="page-header__tagline">
      Monte comandos de SSH Tunnel com diagramas visuais.
    </p>
  </header>

  <!-- Use-case cards -->
  <section class="section">
    <div class="usecase-cards">
      <button class="usecase-card" data-usecase="remote-db">
        <span class="usecase-card__icon">🗄</span>
        <span class="usecase-card__title">Acessar banco remoto</span>
        <span class="usecase-card__desc">PostgreSQL, MySQL via túnel local</span>
      </button>
      <button class="usecase-card" data-usecase="expose-local">
        <span class="usecase-card__icon">🌐</span>
        <span class="usecase-card__title">Expor servidor local</span>
        <span class="usecase-card__desc">Compartilhe seu dev server</span>
      </button>
      <button class="usecase-card" data-usecase="socks-proxy">
        <span class="usecase-card__icon">🔒</span>
        <span class="usecase-card__title">Navegar via proxy</span>
        <span class="usecase-card__desc">SOCKS proxy pela rede remota</span>
      </button>
    </div>
    <div class="usecase-banner" id="usecase-banner" hidden>
      <span id="usecase-banner-text"></span>
      <button class="usecase-banner__close" id="usecase-banner-close" aria-label="Fechar">&times;</button>
    </div>
  </section>

  <!-- Tunnel Entries -->
  <section class="section" id="tunnels-section">
    <div id="tunnels-container"></div>
    <button class="btn btn--accent btn--sm" id="btn-add-tunnel" style="margin-top: 0.5rem;">+ Adicionar túnel</button>
  </section>

  <!-- SSH Connection -->
  <section class="section card">
    <h2 class="section__title">Conexão SSH</h2>
    <div class="form-grid">
      <div class="form-group">
        <label for="ssh-server">Servidor SSH</label>
        <input type="text" id="ssh-server" placeholder="seu-servidor.com" />
      </div>
      <div class="form-group">
        <label for="ssh-user">Usuário <span class="text-muted">(opcional)</span></label>
        <input type="text" id="ssh-user" placeholder="deploy" />
      </div>
      <div class="form-group">
        <label for="ssh-port">Porta <span class="text-muted">(padrão: 22)</span></label>
        <input type="number" id="ssh-port" value="22" min="1" max="65535" />
      </div>
      <div class="form-group">
        <label for="jump-host">Jump Host <span class="text-muted">(opcional)</span> <Tooltip text="Servidor intermediário para chegar ao destino (ProxyJump). Útil quando o servidor SSH não é acessível diretamente pela internet." /></label>
        <input type="text" id="jump-host" placeholder="bastion" />
      </div>
      <div class="form-group">
        <label for="identity-file">Chave Privada <span class="text-muted">(opcional)</span></label>
        <input type="text" id="identity-file" placeholder="~/.ssh/id_ed25519" />
      </div>
    </div>
  </section>

  <!-- Options -->
  <section class="section card">
    <h2 class="section__title">Opções</h2>
    <div class="options-grid">
      <label class="toggle">
        <input type="checkbox" id="opt-no-shell" checked />
        <span class="toggle__track"></span>
        <span>Sem shell (-N) <Tooltip text="Não abre um shell remoto. Use quando só precisa do túnel, sem executar comandos no servidor." /></span>
      </label>
      <label class="toggle">
        <input type="checkbox" id="opt-background" />
        <span class="toggle__track"></span>
        <span>Background (-f) <Tooltip text="Envia o SSH para segundo plano após autenticação. Combine com -N para túneis que rodam como daemon." /></span>
      </label>
      <label class="toggle">
        <input type="checkbox" id="opt-compression" />
        <span class="toggle__track"></span>
        <span>Compressão (-C)</span>
      </label>
      <label class="toggle">
        <input type="checkbox" id="opt-exit-failure" checked />
        <span class="toggle__track"></span>
        <span>ExitOnForwardFailure <Tooltip text="Aborta se a porta do túnel não puder ser reservada. Previne falhas silenciosas onde o SSH conecta mas o túnel não funciona." /></span>
      </label>
    </div>

    <div class="form-grid" style="margin-top: 1rem;">
      <div class="form-group">
        <label for="alive-interval">ServerAliveInterval <span class="text-muted">(s)</span> <Tooltip text="Segundos entre pings de keepalive. Evita que firewalls e NATs derrubem conexões ociosas." /></label>
        <input type="number" id="alive-interval" value="60" min="0" />
      </div>
      <div class="form-group">
        <label for="alive-count">ServerAliveCountMax</label>
        <input type="number" id="alive-count" value="3" min="0" />
      </div>
    </div>
  </section>

  <!-- Diagram -->
  <section class="section" id="diagram-section">
    <h2 class="section__title">Como funciona</h2>
    <div id="diagrams-container"></div>
  </section>

  <!-- Output: SSH Command -->
  <section class="section">
    <h2 class="section__title">Comando SSH</h2>
    <div class="code-preview-wrapper">
      <button class="btn btn--sm copy-btn" data-copy="output-command">Copiar</button>
      <div class="code-preview">
        <code id="output-command">ssh -N -L 8080:localhost:8080 server</code>
      </div>
    </div>
  </section>

  <!-- Output: Autossh -->
  <section class="section">
    <h2 class="section__title">Persistente (autossh)</h2>
    <div class="code-preview-wrapper">
      <button class="btn btn--sm copy-btn" data-copy="output-autossh">Copiar</button>
      <div class="code-preview">
        <code id="output-autossh">autossh -M 0 -N -L 8080:localhost:8080 server</code>
      </div>
    </div>
  </section>

  <!-- Output: SSH Config -->
  <section class="section">
    <div class="config-header">
      <h2 class="section__title">Equivalente ~/.ssh/config</h2>
      <div class="form-group form-group--inline">
        <label for="host-alias">Host alias:</label>
        <input type="text" id="host-alias" value="my-tunnel" class="input--sm" />
      </div>
    </div>
    <div class="code-preview-wrapper">
      <button class="btn btn--sm copy-btn" data-copy="output-config">Copiar</button>
      <div class="code-preview">
        <code id="output-config"></code>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style is:global>
  .page-header {
    text-align: center;
    padding: 2rem 0 1.5rem;
  }

  .page-header__title {
    font-size: 1.75rem;
    letter-spacing: -0.02em;
  }

  .page-header__tagline {
    margin-top: 0.5rem;
    color: var(--text-secondary);
    font-style: italic;
  }

  .section__title {
    font-size: 1rem;
    color: var(--accent);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Tunnel Entry */
  .tunnel-entry {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin-bottom: 0.5rem;
  }

  .tunnel-entry__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .tunnel-entry__type-btns {
    display: flex;
    gap: 0.25rem;
  }

  .tunnel-entry__type-btn {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-secondary);
    color: var(--text-muted);
    cursor: pointer;
    transition: all var(--transition);
  }

  .tunnel-entry__type-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .tunnel-entry__type-btn--active {
    border-color: var(--accent);
    background: var(--accent-glow);
    color: var(--accent);
  }

  .tunnel-entry__remove {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    background: none;
    border: 1px solid var(--danger);
    border-radius: var(--radius);
    color: var(--danger);
    cursor: pointer;
    transition: all var(--transition);
  }

  .tunnel-entry__remove:hover {
    background: var(--danger-glow);
  }

  .tunnel-entry__warning {
    font-size: 0.75rem;
    color: var(--danger);
    margin-top: 0.5rem;
  }

  /* Options Grid */
  .options-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  /* Diagram */
  .diagram {
    margin-bottom: 0.5rem;
  }

  .diagram__flow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0.5rem 0;
  }

  .diagram__node {
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.875rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .diagram__node--left {
    background: var(--accent-glow);
    border: 1px solid var(--accent-dim);
    color: var(--accent);
  }

  .diagram__node--middle {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-primary);
  }

  .diagram__node--right {
    background: var(--success-glow);
    border: 1px solid var(--success);
    color: var(--success);
  }

  .diagram__arrow {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .diagram__desc {
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 0.75rem;
    line-height: 1.5;
  }

  /* Config header */
  .config-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .config-header .section__title {
    margin-bottom: 0;
  }

  .form-group--inline {
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
  }

  .input--sm {
    width: 140px;
    font-size: 0.875rem;
    padding: 0.25rem 0.5rem;
  }

  @media (max-width: 640px) {
    .options-grid {
      grid-template-columns: 1fr;
    }

    .diagram__flow {
      flex-direction: column;
    }

    .config-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .tunnel-entry__type-btns {
      flex-wrap: wrap;
    }
  }
</style>

<script>
  import {
    generateSshCommand,
    generateAutosshCommand,
    generateSshConfig,
    generateDiagram,
  } from '../lib/tunnel-generator';
  import type {
    TunnelSpec,
    TunnelOptions,
    TunnelType,
  } from '../lib/types';
  import { copyToClipboard } from '../lib/clipboard';

  // --- State ---
  interface TunnelEntry {
    id: number;
    type: TunnelType;
    listenPort: number;
    bindAddr: string;
    destHost: string;
    destPort: number;
  }

  let nextId = 1;
  let tunnelEntries: TunnelEntry[] = [];

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;

  const tunnelsContainer = $<HTMLElement>('tunnels-container');
  const diagramsContainer = $<HTMLElement>('diagrams-container');
  const outputCommand = $<HTMLElement>('output-command');
  const outputAutossh = $<HTMLElement>('output-autossh');
  const outputConfig = $<HTMLElement>('output-config');

  // --- Defaults per type ---
  const typeDefaults: Record<TunnelType, { listenPort: number; destHost: string; destPort: number }> = {
    local: { listenPort: 8080, destHost: 'localhost', destPort: 8080 },
    remote: { listenPort: 8080, destHost: 'localhost', destPort: 3000 },
    dynamic: { listenPort: 1080, destHost: '', destPort: 0 },
  };

  const typeLabels: Record<TunnelType, { listen: string; dest: string; destPort: string }> = {
    local: { listen: 'Porta local', dest: 'Host remoto', destPort: 'Porta remota' },
    remote: { listen: 'Porta remota', dest: 'Host local', destPort: 'Porta local' },
    dynamic: { listen: 'Porta SOCKS', dest: '', destPort: '' },
  };

  // --- Create entry ---
  function createEntry(type: TunnelType): TunnelEntry {
    const d = typeDefaults[type];
    return { id: nextId++, type, listenPort: d.listenPort, bindAddr: '', destHost: d.destHost, destPort: d.destPort };
  }

  // --- Render all tunnel entries ---
  function renderEntries() {
    tunnelsContainer.innerHTML = '';
    for (const entry of tunnelEntries) {
      tunnelsContainer.appendChild(buildEntryEl(entry));
    }
    update();
  }

  function buildEntryEl(entry: TunnelEntry): HTMLElement {
    const el = document.createElement('div');
    el.className = 'tunnel-entry';
    const showDest = entry.type !== 'dynamic';
    const labels = typeLabels[entry.type];
    const canRemove = tunnelEntries.length > 1;

    el.innerHTML = `
      <div class="tunnel-entry__header">
        <div class="tunnel-entry__type-btns">
          ${(['local', 'remote', 'dynamic'] as TunnelType[]).map(t =>
            `<button class="tunnel-entry__type-btn${t === entry.type ? ' tunnel-entry__type-btn--active' : ''}" data-entry-type="${t}">${t === 'local' ? '-L Local' : t === 'remote' ? '-R Remote' : '-D Dynamic'}</button>`
          ).join('')}
        </div>
        ${canRemove ? `<button class="tunnel-entry__remove" data-remove="${entry.id}">Remover</button>` : ''}
      </div>
      <div class="form-grid">
        <div class="form-group">
          <label>${labels.listen}</label>
          <input type="number" data-field="listenPort" value="${entry.listenPort}" min="1" max="65535" />
        </div>
        <div class="form-group">
          <label>Bind Address <span class="text-muted">(opcional)</span></label>
          <input type="text" data-field="bindAddr" value="${entry.bindAddr}" placeholder="localhost" />
        </div>
        <div class="form-group" ${showDest ? '' : 'hidden'}>
          <label>${labels.dest}</label>
          <input type="text" data-field="destHost" value="${entry.destHost}" />
        </div>
        <div class="form-group" ${showDest ? '' : 'hidden'}>
          <label>${labels.destPort}</label>
          <input type="number" data-field="destPort" value="${entry.destPort}" min="1" max="65535" />
        </div>
      </div>
      <div class="tunnel-entry__warning" data-warning="${entry.id}" hidden></div>
    `;

    // Type switching
    el.querySelectorAll<HTMLButtonElement>('.tunnel-entry__type-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const newType = btn.dataset.entryType as TunnelType;
        entry.type = newType;
        const d = typeDefaults[newType];
        entry.listenPort = d.listenPort;
        entry.destHost = d.destHost;
        entry.destPort = d.destPort;
        entry.bindAddr = '';
        renderEntries();
      });
    });

    // Remove
    const removeBtn = el.querySelector(`[data-remove="${entry.id}"]`);
    removeBtn?.addEventListener('click', () => {
      tunnelEntries = tunnelEntries.filter(e => e.id !== entry.id);
      renderEntries();
    });

    // Field changes
    el.querySelectorAll<HTMLInputElement>('[data-field]').forEach(input => {
      const handler = () => {
        const field = input.dataset.field!;
        if (field === 'listenPort' || field === 'destPort') {
          (entry as Record<string, unknown>)[field] = Number(input.value) || 0;
        } else {
          (entry as Record<string, unknown>)[field] = input.value;
        }
        update();
      };
      input.addEventListener('input', handler);
      input.addEventListener('change', handler);
    });

    return el;
  }

  // --- Build specs from entries ---
  function getSpecs(): TunnelSpec[] {
    return tunnelEntries.map(e => {
      const bind = e.bindAddr || undefined;
      switch (e.type) {
        case 'local':
          return { type: 'local' as const, localPort: e.listenPort, remoteHost: e.destHost || 'localhost', remotePort: e.destPort, bindAddress: bind };
        case 'remote':
          return { type: 'remote' as const, remotePort: e.listenPort, localHost: e.destHost || 'localhost', localPort: e.destPort, bindAddress: bind };
        case 'dynamic':
          return { type: 'dynamic' as const, localPort: e.listenPort, bindAddress: bind };
      }
    });
  }

  function getOptions(): TunnelOptions {
    return {
      sshServer: ($<HTMLInputElement>('ssh-server')).value || 'server',
      sshUser: ($<HTMLInputElement>('ssh-user')).value || undefined,
      sshPort: Number(($<HTMLInputElement>('ssh-port')).value) || 22,
      jumpHost: ($<HTMLInputElement>('jump-host')).value || undefined,
      identityFile: ($<HTMLInputElement>('identity-file')).value || undefined,
      noShell: ($<HTMLInputElement>('opt-no-shell')).checked,
      background: ($<HTMLInputElement>('opt-background')).checked,
      compression: ($<HTMLInputElement>('opt-compression')).checked,
      exitOnForwardFailure: ($<HTMLInputElement>('opt-exit-failure')).checked,
      serverAliveInterval: Number(($<HTMLInputElement>('alive-interval')).value) || undefined,
      serverAliveCountMax: Number(($<HTMLInputElement>('alive-count')).value) || undefined,
    };
  }

  // --- Warnings ---
  function checkWarnings() {
    // Check duplicate local ports
    const localPorts = new Map<number, number[]>();
    for (const e of tunnelEntries) {
      if (e.type === 'local' || e.type === 'dynamic') {
        const ids = localPorts.get(e.listenPort) || [];
        ids.push(e.id);
        localPorts.set(e.listenPort, ids);
      }
    }

    // Check multiple dynamic
    const dynamicCount = tunnelEntries.filter(e => e.type === 'dynamic').length;

    for (const e of tunnelEntries) {
      const warningEl = document.querySelector(`[data-warning="${e.id}"]`) as HTMLElement | null;
      if (!warningEl) continue;

      const warnings: string[] = [];
      const portIds = localPorts.get(e.listenPort);
      if (portIds && portIds.length > 1 && (e.type === 'local' || e.type === 'dynamic')) {
        warnings.push(`Porta local ${e.listenPort} usada em mais de um túnel.`);
      }
      if (e.type === 'dynamic' && dynamicCount > 1) {
        warnings.push('Apenas um túnel dinâmico (-D) por comando é recomendado.');
      }

      warningEl.hidden = warnings.length === 0;
      warningEl.textContent = warnings.join(' ');
    }
  }

  // --- Update outputs ---
  function update() {
    const tunnels = getSpecs();
    const options = getOptions();
    const config = { tunnels, options };
    const alias = ($<HTMLInputElement>('host-alias')).value || 'my-tunnel';

    outputCommand.textContent = generateSshCommand(config);
    outputAutossh.textContent = generateAutosshCommand(config);
    outputConfig.textContent = generateSshConfig(config, alias);

    // Diagrams
    diagramsContainer.innerHTML = '';
    for (const tunnel of tunnels) {
      const diagram = generateDiagram(tunnel, options);
      const div = document.createElement('div');
      div.className = 'diagram card';
      div.innerHTML = `
        <div class="diagram__flow">
          <span class="diagram__node diagram__node--left">${diagram.left}</span>
          <span class="diagram__arrow">&mdash;&mdash; SSH &mdash;&mdash;&gt;</span>
          <span class="diagram__node diagram__node--middle">${diagram.middle}</span>
          <span class="diagram__arrow">&mdash;&mdash;&gt;</span>
          <span class="diagram__node diagram__node--right">${diagram.right}</span>
        </div>
        <p class="diagram__desc">${diagram.description}</p>
      `;
      diagramsContainer.appendChild(div);
    }

    checkWarnings();
  }

  // --- Add tunnel ---
  $<HTMLButtonElement>('btn-add-tunnel').addEventListener('click', () => {
    tunnelEntries.push(createEntry('local'));
    renderEntries();
  });

  // --- Listen to SSH/options inputs ---
  document.querySelectorAll<HTMLInputElement>('#ssh-server, #ssh-user, #ssh-port, #jump-host, #identity-file, #opt-no-shell, #opt-background, #opt-compression, #opt-exit-failure, #alive-interval, #alive-count, #host-alias').forEach(input => {
    if (!input) return;
    input.addEventListener('input', update);
    input.addEventListener('change', update);
  });

  // --- Copy buttons ---
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.dataset.copy;
      if (!targetId) return;
      const target = $(targetId);
      if (!target) return;
      const success = await copyToClipboard(target.textContent || '');
      const original = btn.textContent;
      btn.textContent = success ? 'Copiado!' : 'Erro';
      setTimeout(() => (btn.textContent = original), 1500);
    });
  });

  // --- Use-case cards ---
  const usecaseBanner = $<HTMLElement>('usecase-banner');
  const usecaseBannerText = $<HTMLElement>('usecase-banner-text');

  interface UsecaseEntry { type: TunnelType; listenPort: number; destHost: string; destPort: number }
  interface Usecase { tunnels: UsecaseEntry[]; server: string; user: string; alias: string; banner: string }

  const usecases: Record<string, Usecase> = {
    'remote-db': {
      tunnels: [{ type: 'local', listenPort: 5432, destHost: 'db.internal', destPort: 5432 }],
      server: 'bastion.exemplo.com', user: 'deploy', alias: 'db-tunnel',
      banner: 'Exemplo carregado — após conectar, use "psql -h localhost -p 5432" para acessar o banco remoto como se fosse local.',
    },
    'expose-local': {
      tunnels: [{ type: 'remote', listenPort: 8080, destHost: 'localhost', destPort: 3000 }],
      server: 'servidor.exemplo.com', user: 'deploy', alias: 'expose-dev',
      banner: 'Exemplo carregado — seu colega poderá acessar seu app local em servidor.exemplo.com:8080.',
    },
    'socks-proxy': {
      tunnels: [{ type: 'dynamic', listenPort: 1080, destHost: '', destPort: 0 }],
      server: 'proxy.exemplo.com', user: 'usuario', alias: 'socks-proxy',
      banner: 'Exemplo carregado — configure seu navegador para usar proxy SOCKS5 em localhost:1080.',
    },
  };

  document.querySelectorAll<HTMLButtonElement>('.usecase-card').forEach((card) => {
    card.addEventListener('click', () => {
      const uc = usecases[card.dataset.usecase!];
      if (!uc) return;

      tunnelEntries = uc.tunnels.map(t => ({
        id: nextId++, type: t.type, listenPort: t.listenPort,
        bindAddr: '', destHost: t.destHost, destPort: t.destPort,
      }));

      ($<HTMLInputElement>('ssh-server')).value = uc.server;
      ($<HTMLInputElement>('ssh-user')).value = uc.user;
      ($<HTMLInputElement>('host-alias')).value = uc.alias;

      usecaseBannerText.textContent = uc.banner;
      usecaseBanner.hidden = false;

      renderEntries();
      $<HTMLElement>('tunnels-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  $<HTMLElement>('usecase-banner-close').addEventListener('click', () => {
    usecaseBanner.hidden = true;
  });

  // --- Initial state: one local tunnel ---
  tunnelEntries.push(createEntry('local'));
  renderEntries();
</script>
